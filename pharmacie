import java.util.ArrayList;
import java.util.Date;
import java.util.List;

// --- Classe représentant un Pharmacien ---
class Pharmacien {
    private String idPharmacien;
    private String nom;
    private String specialite;

    public Pharmacien(String idPharmacien, String nom, String specialite) {
        this.idPharmacien = idPharmacien;
        this.nom = nom;
        this.specialite = specialite;
    }

    // Getters
    public String getNom() { return nom; }
    public String getIdPharmacien() { return idPharmacien; }

    @Override
    public String toString() {
        return "Pharmacien: " + nom + " (ID: " + idPharmacien + ")";
    }
}

// --- Classe représentant une Ordonnance ---
class Ordonnance {
    private String idOrdonnance;
    private String nomPatient;
    private Date dateEmission;
    private List<String> medicaments;
    private boolean estServie;
    private Pharmacien pharmacienResponsable; // Relation avec le Pharmacien

    public Ordonnance(String idOrdonnance, String nomPatient) {
        this.idOrdonnance = idOrdonnance;
        this.nomPatient = nomPatient;
        this.dateEmission = new Date();
        this.medicaments = new ArrayList<>();
        this.estServie = false;
    }

    public void ajouterMedicament(String medicament) {
        this.medicaments.add(medicament);
    }

    public void servirOrdonnance(Pharmacien pharmacien) {
        this.pharmacienResponsable = pharmacien;
        this.estServie = true;
        System.out.println("L'ordonnance " + idOrdonnance + " a été servie par : " + pharmacien.getNom());
    }

    @Override
    public String toString() {
        String statut = estServie ? "Servie par " + pharmacienResponsable.getNom() : "En attente";
        return "Ordonnance N°: " + idOrdonnance + " | Patient: " + nomPatient + " | Statut: " + statut + " | Médicaments: " + medicaments;
    }
}

// --- Classe Principale pour la gestion ---
public class GestionPharmacie {
    public static void main(String[] args) {
        // 1. Création des pharmaciens
        Pharmacien p1 = new Pharmacien("PH001", "Dr. Jean Dupont", "Titulaire");
        
        // 2. Création d'une ordonnance
        Ordonnance ord1 = new Ordonnance("ORD-2024-001", "Alice Martin");
        ord1.ajouterMedicament("Paracétamol 500mg");
        ord1.ajouterMedicament("Amoxicilline 1g");

        // 3. Affichage avant traitement
        System.out.println("--- État Initial ---");
        System.out.println(ord1);

        // 4. Traitement de l'ordonnance par le pharmacien
        System.out.println("\n--- Traitement en cours ---");
        ord1.servirOrdonnance(p1);

        // 5. Affichage final
        System.out.println("\n--- État Final ---");
        System.out.println(ord1);
    }
}